# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Supabase PostgreSQL - use pooler URL port 6543 for Transaction mode)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Groq (free tier - primary AI summarization provider)
GROQ_API_KEY=your-groq-api-key

# Google Gemini (free tier - fallback AI summarization provider)
GEMINI_API_KEY=your-gemini-api-key

# GitHub (optional - enables GitHub trending adapter with higher rate limits)
GITHUB_TOKEN=your-github-pat

# GitHub PAT for manual refresh (optional - enables manual pipeline trigger from dashboard)
# Requires fine-grained PAT with actions:write scope on this repository
# Repo: 000Janela000/dev-news (override with GITHUB_REPO env var)
GH_PAT=your-github-pat-with-actions-write
